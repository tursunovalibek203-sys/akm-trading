# App
APP_NAME="Trading AI Platform"
ENVIRONMENT=development
DEBUG=true

# Database (Docker Compose dan)
DATABASE_URL=postgresql://trading_user:trading_pass@localhost:5432/trading_db

# Redis (Docker Compose dan)
REDIS_URL=redis://localhost:6379

# JWT — RSA 2048-bit kalitlar
# Yaratish: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# API kalit shifrlash (AES-256-GCM) — 32 bayt random
# Yaratish: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Claude API (Faza 2 dan kerak)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-20250514
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_OPUS=claude-opus-4-20250514

# Binance
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443

# Bybit
BYBIT_BASE_URL=https://api.bybit.com

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Sentry (ixtiyoriy)
SENTRY_DSN=
